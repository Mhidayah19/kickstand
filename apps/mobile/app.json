{
  "expo": {
    "name": "Kickstand",
    "slug": "mobile-hid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kickstand",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kickstandhid.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Kickstand needs access to your photos to attach receipts to service logs.",
          "cameraPermission": "Kickstand needs camera access to photograph receipts."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kickstand needs camera access to scan workshop receipts."
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "@sentry/react-native/expo",
        {
          "organization": "kickstand",
          "project": "kickstand"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c6534e11-0a54-493b-b4df-7ca7635084fe"
      }
    },
    "owner": "kickstand-hid",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c6534e11-0a54-493b-b4df-7ca7635084fe"
    }
  }
}
